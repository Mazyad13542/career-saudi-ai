# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── PayPal ────────────────────────────────────────────────────────────────────
# Only the publishable client ID goes in the frontend (VITE_ prefix required)
VITE_PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id

# PayPal environment settings (not exposed to frontend — server-side reference only)
PAYPAL_SECRET=your_paypal_secret_NEVER_EXPOSE_IN_FRONTEND
PAYPAL_CURRENCY=USD
PAYPAL_ENVIRONMENT=sandbox          # change to "live" for production
PAYPAL_SUCCESS_URL=/payment-success
PAYPAL_CANCEL_URL=/pricing
