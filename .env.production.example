# ============================================================
#  قِمّة — Production Environment Variables
#  Copy this to .env for local dev, or add to Vercel Dashboard
#  for production deployment.
#
#  SECURITY RULES:
#    - Variables prefixed VITE_ are exposed to the browser bundle
#    - NEVER add PAYPAL_SECRET or SUPABASE_SERVICE_ROLE_KEY with VITE_ prefix
#    - Only VITE_PAYPAL_CLIENT_ID is safe in frontend (publishable key)
# ============================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://eerduxtweznidslizpgb.supabase.co
VITE_SUPABASE_ANON_KEY=<your_supabase_anon_key>

# ── PayPal (Frontend — publishable only) ─────────────────────────────────────
# Sandbox client ID (for testing):
#   AR5i-MkyvCg0MLjJzvYzgqwRwU3DlKJibaeRsZz_yoDGQXB2WNxsedIYYpHQphdqQbHPS3mB2BPEYo5z
# Live client ID (switch when going live):
VITE_PAYPAL_CLIENT_ID=<your_paypal_live_client_id>

# ── PayPal Server-side Reference (NOT exposed to frontend) ───────────────────
# These are reference values only — Supabase Edge Functions or a backend should use them.
# NEVER prefix these with VITE_ — Vite will NOT include them in the bundle.
# PAYPAL_SECRET=<your_paypal_secret>
# PAYPAL_ENVIRONMENT=live
# PAYPAL_SUCCESS_URL=/payment-success
# PAYPAL_CANCEL_URL=/#pricing

# ── Resend (Email — Edge Function secret, set via Supabase secrets) ───────────
# Set with: supabase secrets set RESEND_API_KEY=re_xxxxx
# RESEND_API_KEY=re_<your_resend_api_key>

# ── Site URL ──────────────────────────────────────────────────────────────────
VITE_SITE_URL=https://qimma.sa
